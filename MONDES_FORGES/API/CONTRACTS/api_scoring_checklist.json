{
  "version": "1.0",
  "description": "Grille de scoring pour identifier la cible optimale \u00e0 assi\u00e9ger",
  "scoring_formula": "score = (popularite * 0.35) + (latence_score * 0.25) + (wrappers_score * 0.20) + (frustration_pricing_score * 0.20)",
  "dimensions": {
    "popularite": {
      "weight": 0.35,
      "description": "Score de popularit\u00e9 RapidAPI (0-10)",
      "scoring": {
        "9.5-10": 100,
        "8.5-9.4": 75,
        "7.0-8.4": 50,
        "5.0-6.9": 25,
        "<5.0": 0
      }
    },
    "latence_score": {
      "weight": 0.25,
      "description": "Latence moyenne de l'API leader (ms) \u2014 plus c'est \u00e9lev\u00e9, mieux c'est pour nous",
      "scoring": {
        ">5000ms": 100,
        "2000-5000ms": 75,
        "1000-1999ms": 50,
        "500-999ms": 25,
        "<500ms": 0
      }
    },
    "wrappers_score": {
      "weight": 0.2,
      "description": "Signal adoption agents \u2014 nombre de repos GitHub qui importent l'API",
      "scoring": {
        ">500 repos": 100,
        "200-500 repos": 75,
        "50-199 repos": 50,
        "10-49 repos": 25,
        "<10 repos": 0
      }
    },
    "frustration_pricing_score": {
      "weight": 0.2,
      "description": "Niveau de frustration sur le pricing dans les reviews et issues",
      "scoring": {
        ">30% reviews n\u00e9gatives sur prix": 100,
        "20-30% reviews n\u00e9gatives": 75,
        "10-19% reviews n\u00e9gatives": 50,
        "1-9% reviews n\u00e9gatives": 25,
        "0% reviews n\u00e9gatives": 0
      }
    }
  },
  "thresholds": {
    "SIEGEZ": 70,
    "ATTENDEZ": 50,
    "REORIENTEZ": 0
  },
  "angle_types": [
    "prix_agressif",
    "endpoint_focus_email",
    "endpoint_focus_bulk",
    "endpoint_focus_company",
    "endpoint_focus_profile",
    "latence_ultra_rapide",
    "format_json_pur",
    "format_json_csv",
    "format_json_resume",
    "niche_ecommerce",
    "niche_recrutement",
    "niche_sales",
    "niche_marketing",
    "tier_freemium_genereux",
    "tier_micro_2usd",
    "tier_standard_5usd",
    "tier_pro_10usd",
    "tier_agency_25usd",
    "async_optimise",
    "cache_intelligent"
  ],
  "iron_warrior_count": 20
}