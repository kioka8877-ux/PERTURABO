# PERTURABO — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env dans git

# AI Gateway (compatible OpenRouter)
AI_GATEWAY_BASE_URL=https://gateway.example.com
AI_GATEWAY_API_KEY=sk-your-key-here

# GitHub API (F01 SENTINEL — signal agents)
GITHUB_TOKEN=ghp_your-token-here

# RapidAPI (F05 GRAND COMPASS — déploiement)
RAPIDAPI_KEY=your-rapidapi-key-here

# Railway (F05 — déploiement Iron Warriors)
RAILWAY_TOKEN=your-railway-token-here
